{
  "name": "mui-notifications",
  "version": "0.1.3",
  "description": "Application notifications component using Material UI.",
  "type": "module",
  "files": ["dist"],
  "main": "./dist/mui-notifications.cjs.js",
  "module": "./dist/mui-notifications.es.js",
  "types": "./dist/main.d.ts",
  "exports": {
    ".": {
      "import": "./dist/mui-notifications.es.js",
      "require": "./dist/mui-notifications.cjs.js",
      "types": "./dist/main.d.ts"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -p ./tsconfig-build.json && vite build",
    "prepublishOnly": "npm run build",
    "lint": "eslint . --ext ts,tsx",
    "type-check": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "@mui/material": "^5.0.0 || ^6.0.0",
    "@emotion/react": "^11.0.0",
    "@emotion/styled": "^11.0.0"
  },
  "peerDependenciesMeta": {
    "@mui/material": {
      "optional": false
    }
  },
  "devDependencies": {
    "@mui/icons-material": "^6.4.0",
    "@mui/material": "^6.4.0",
    "@mui/utils": "^6.4.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "typescript": "~6.0.2",
    "vite": "^8.0.12",
    "vite-plugin-dts": "^5.0.1"
  }
}