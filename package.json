{
  "name": "mui-notifications",
  "version": "0.1.2",
  "description": "Application notifications component using Material UI.",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/mui-notifications.cjs.js",
  "module": "./dist/mui-notifications.es.js",
  "types": "./dist/main.d.ts",
  "exports": {
    ".": {
      "import": "./dist/mui-notifications.es.js",
      "require": "./dist/mui-notifications.cjs.js",
      "types": "./dist/main.d.ts"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --p ./tsconfig-build.json && vite build",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "@mui/material": "^7.0.0 || ^8.0.0 || ^9.0.0"
  },
  "peerDependencies": {
    "@mui/icons-material": "^9.0.1",
    "@mui/material": "^9.0.1",
    "@mui/utils": "^9.0.1",
    "@emotion/react": "^11.0.0",
    "@emotion/styled": "^11.0.0"
  },
  "devDependencies": {
    "@mui/icons-material": "^9.0.1",
    "@mui/material": "^9.0.1",
    "@mui/utils": "^9.0.1",
    "@emotion/react": "^11.0.0",
    "@emotion/styled": "^11.0.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vite-plugin-dts": "^5.0.1",
    "vitest": "^4.1.7"
  }
}
