{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "jsx": "react-jsx",
    
    "rootDir": "./lib",          
    "declaration": true,
    "declarationDir": "dist",
    "emitDeclarationOnly": true,
    
    "isolatedModules": true,
    "skipLibCheck": true
  },
  "include": ["lib"],
  "exclude": ["node_modules", "**/*.test.tsx", "**/*.spec.tsx"]
}